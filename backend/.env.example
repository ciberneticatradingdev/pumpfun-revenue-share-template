# Required - Your deployer wallet private key (base58)
WALLET_PRIVATE_KEY=

# Required - Token mint address
TOKEN_MINT=

# Required - PostgreSQL connection (Railway provides this automatically)
DATABASE_URL=

# Required - Solana RPC endpoint
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Optional
CYCLE_MS=90000
MIN_HOLDING_PERCENT=0.5
PORT=4000
